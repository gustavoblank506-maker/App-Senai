{
  "expo": {
    "name": "meuApp",
    "slug": "meuApp",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/senai_icon.png",

    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/senai_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06123C"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/senai_icon.png",
        "backgroundColor": "#06123C"
      },
      "edgeToEdgeEnabled": true
    },

    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}